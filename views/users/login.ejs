<% layout("/layouts/boilerplate") %>

<div class="auth-wrap">
  <div class="form-card">
    <h1>Log in</h1>
    <p class="text-muted mb-4">Welcome back to Wanderlust.</p>

    <form action="/login" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input name="username" type="text" id="username" class="form-control" required placeholder="Your username">
        <div class="invalid-feedback">Please enter your username.</div>
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input name="password" type="password" id="password" class="form-control" required placeholder="Your password">
        <div class="invalid-feedback">Please enter your password.</div>
      </div>
      <button type="submit" class="btn-app btn-app-primary">Log in</button>
    </form>

    <p class="form-text">Don't have an account? <a href="/signup">Sign up</a></p>
  </div>
</div>
