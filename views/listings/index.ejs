<% layout("/layouts/boilerplate") %>

<!-- <style>
  .filter{
    margin-top: 1rem;
  }
</style> -->

<style>
  #filters{
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .filter{
    text-align: center;
    margin-right: 2rem;
    margin-top: 1rem;
    opacity: 0.8;
  }

  .filter:hover{
    opacity: 1;
    cursor: pointer;
  }

  .filter p{
    font-size: 0.8rem;
  }

  .filter-link{
    text-decoration: none;
    color: inherit;
  }

  .tax-info{
    display: none;
  }

  .tax-toggle{
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.5rem;
    padding: 1rem;
    margin-left: auto;
    display: flex;
    align-items: center;
  }
</style>

<div id="filters">
  <a href="/listings" class="filter-link">
    <div class="filter" data-category="all">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </div>
  </a>

  <a href="/listings?category=rooms" class="filter-link">
    <div class="filter" data-category="Rooms">
      <div><i class="fa-solid fa-bed"></i> </div>
      <p>Rooms</p>
    </div>
  </a>

  <a href="/listings?category=iconic+cities" class="filter-link">
    <div class="filter" data-category="Iconic Cities">
      <div><i class="fa-duotone fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
    </div>
  </a>

  <a href="/listings?category=mountains" class="filter-link">
    <div class="filter" data-category="Mountains">
      <div><i class="fa-duotone fa-solid fa-mountain"></i></div>    
      <p>Mountains</p>
    </div>
  </a>

  <a href="/listings?category=castles" class="filter-link">
    <div class="filter" data-category="Castles">
      <div><i class="fa-brands fa-fort-awesome"></i></div>
      <p>Castles</p>
    </div>
  </a>

  <a href="/listings?category=amazing+pools" class="filter-link">
    <div class="filter" data-category="Amazing Pools">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amazing Pool</p>
    </div>
  </a>

  <a href="/listings?category=camping" class="filter-link">
    <div class="filter" data-category="Camping">
      <div><i class="fa-solid fa-campground"></i></div>    
      <p>Camping</p>
    </div>
  </a>

  <a href="/listings?category=farms" class="filter-link">
    <div class="filter" data-category="Farms">
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
    </div>
  </a>

  <a href="/listings?category=arctic" class="filter-link">
    <div class="filter" data-category="Arctic">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
    </div>
  </a>
  <a href="/listings?category=beaches" class="filter-link">
    <div class="filter" data-category="Beaches">
      <div><i class="fa-solid fa-umbrella-beach"></i></div>
      <p>Beaches</p>
    </div>
  </a>


  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
  </div>
</div>


<section class="listings-hero">
  <h1>Find your next stay</h1>
  <p>Discover unique places and experiences around the world.</p>
</section>

<div id="listings-container"
     class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
  <% for(let listing of listings) { %>
  <div class="col">
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card listing-card">
        <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://placehold.co/600x400/f8f6f2/57534e?text=No+image' %>" class="card-img-top" alt="<%= listing.title %>">
        <div class="card-body">
          <h5 class="card-title"><%= listing.title %></h5>
          <div class="card-meta">
            <span class="card-price">&#8377;<%= listing.price.toLocaleString("en-IN") %></span>
            <span class="text-muted"> / night
              <i class="tax-info"> &nbsp; &nbsp; &nbsp; <b>18% GST</b></i>
            </span>
          </div>
        </div>
      </div>
    </a>
  </div>
  <% } %>
</div>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () =>{
    let taxInfo = document.getElementsByClassName("tax-info");
    for(info of taxInfo){
      if(info.style.display === "inline"){
        info.style.display = "none";
      } else {
        info.style.display = "inline";
      }
    }
  });
</script>
