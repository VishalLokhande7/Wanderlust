<% layout("/layouts/boilerplate") %>

<div class="form-page">
  <div class="form-card">
    <h1>Create a new listing</h1>
    <p class="text-muted mb-4">Share a place you love with other travelers.</p>

    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input id="title" type="text" name="listing[title]" placeholder="e.g. Cozy beach house in Goa" class="form-control" required>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a title.</div>
      </div>

      <div class="mb-3">
        <label for="desc" class="form-label">Description</label>
        <textarea id="desc" name="listing[description]" class="form-control" rows="4" required placeholder="Describe the place, amenities, and what makes it special..."></textarea>
        <div class="invalid-feedback">Please add a description.</div>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Cover image</label>
        <input id="image" type="file" name="listing[image]" class="form-control" accept="image/png,image/jpeg,image/jpg" required>
        <div class="invalid-feedback">Please upload an image.</div>
        required
      </div>

      <div class="row g-3">
        <div class="col-md-4">
          <label for="price" class="form-label">Price per night (&#8377;)</label>
          <input id="price" type="number" name="listing[price]" placeholder="1200" class="form-control" min="0" required>
          <div class="invalid-feedback">Enter a valid price.</div>
        </div>
        <div class="col-md-8">
          <label for="country" class="form-label">Country</label>
          <input id="country" type="text" name="listing[country]" placeholder="India" class="form-control" required>
          <div class="invalid-feedback">Please enter country.</div>
        </div>
      </div>

      <div class="mb-4 mt-3">
        <label for="location" class="form-label">Location</label>
        <input id="location" type="text" name="listing[location]" placeholder="Mumbai, Maharashtra" class="form-control" required>
        <div class="invalid-feedback">Please enter location.</div>
      </div>

      <button type="submit" class="btn-app btn-app-primary">Create listing</button>
    </form>
  </div>
</div>
